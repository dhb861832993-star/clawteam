# OpenClaw Dashboard Configuration
# Copy this file to .env and customize for your setup

# ===========================================
# Server Configuration
# ===========================================

# Port for the Dashboard API server
OPENCLAW_DASHBOARD_PORT=3001

# Host to bind the server to
OPENCLAW_DASHBOARD_HOST=localhost

# ===========================================
# OpenClaw CLI Configuration
# ===========================================

# Command or path to OpenClaw binary
# Examples:
#   - "openclaw" (if in PATH)
#   - "/usr/local/bin/openclaw" (full path)
#   - "node /path/to/openclaw/dist/cli.js" (development)
OPENCLAW_COMMAND=openclaw

# Timeout for OpenClaw CLI commands (in milliseconds)
OPENCLAW_TIMEOUT=60000

# Path to OpenClaw log files
# The dashboard will read logs from this directory
OPENCLAW_LOG_PATH=/tmp/openclaw

# Base path for agent workspaces
# Used to locate agent files and configurations
OPENCLAW_WORKSPACE_BASE=~/.openclaw/workspace

# ===========================================
# Gateway WebSocket Configuration
# ===========================================

# WebSocket URL for OpenClaw Gateway
# This is the gateway started by `openclaw gateway start`
OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789

# Gateway authentication token
# Find it in ~/.openclaw/openclaw.json under gateway.auth.token
OPENCLAW_GATEWAY_TOKEN=

# Interval to attempt reconnection (in milliseconds)
OPENCLAW_GATEWAY_RECONNECT_INTERVAL=5000

# Timeout for gateway requests (in milliseconds)
OPENCLAW_GATEWAY_REQUEST_TIMEOUT=30000

# ===========================================
# API Configuration (Frontend)
# ===========================================

# Base path for API endpoints
OPENCLAW_API_BASE=/api